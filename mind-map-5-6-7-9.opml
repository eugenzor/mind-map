<opml version="2.0">
    <head>
        <title>Прокрастинація і контроль (Розділи 5, 6, 7, 9)</title>
    </head>
    <body>
        <outline text="Прокрастинація і контроль">

            <outline text="5. Боротьба з відкладанням на потім">
                <outline text="Відволікання й відкладання на потім">
                    <outline text="Прокрастинація — одна з найбільших проблем покоління"/>
                    <outline text="Багато відволікальних чинників: соцмережі, пошта, телефон"/>
                    <outline text="Навіть почавши роботу, не закриваємо вкладки що відволікають"/>
                </outline>
                <outline text="Відкладання й дискомфорт">
                    <outline text="Ми відкладаємо те, що приносить нам дискомфорт"/>
                    <outline text="Больові центри мозку активізуються від самого наміру"/>
                    <outline text="Нестерпним є передчуття, а не сама дія — біль минає коли починаєш"/>
                    <outline text="Страх перед заняттям може забирати більше енергії ніж саме заняття"/>
                </outline>
                <outline text="Як мозок відкладає на потім">
                    <outline text="1. Думка про неприємне завдання — больові центри активізуються"/>
                    <outline text="2. Мозок шукає спосіб усунути біль — перемикає увагу"/>
                    <outline text="3. Увага переходить на щось приємніше (соцмережі, повідомлення)"/>
                    <outline text="4. Тимчасове полегшення — але час втрачено"/>
                </outline>
                <outline text="Прокрастинація як залежність">
                    <outline text="Дає тимчасове збудження та звільнення від нудної реальності"/>
                    <outline text="Легко переконати себе в ірраціональних виправданнях"/>
                    <outline text="Може стати джерелом гордості («я працюю під тиском»)"/>
                    <outline text="Вищий рівень стресу, гірший стан здоров'я, нижчі оцінки"/>
                </outline>
                <outline text="Аналогія з отрутою">
                    <outline text="Маленькі дози не дають помітної шкоди"/>
                    <outline text="Поступово звикаєш — виглядаєш здоровим"/>
                    <outline text="Довготермінові наслідки руйнівні"/>
                </outline>
                <outline text="Звички як зомбі-режим">
                    <outline text="Звички зберігають енергію мозку для інших справ"/>
                    <outline text="Автоматичні реакції без повного усвідомлення"/>
                    <outline text="Можуть бути добрими й поганими — треба взяти під контроль"/>
                    <outline text="Стратегії протидії прості, але не очевидні"/>
                    <outline text="Сила волі — останній засіб, не перший"/>
                </outline>
            </outline>

            <outline text="6. Скрізь зомбі">
                <outline text="Звички як явище">
                    <outline text="Мозок переходить у запрограмований (зазомбований) режим"/>
                    <outline text="Звички зберігають нашу енергію"/>
                    <outline text="Можуть бути короткими (секунди) або тривалими"/>
                </outline>
                <outline text="Чотири елементи звички">
                    <outline text="1. Зачіпка (cue)">
                        <outline text="Те, що переводить вас у зазомбований режим"/>
                        <outline text="Категорії: місце, час, самопочуття, реакції на інших людей"/>
                        <outline text="Сама по собі ні позитивна, ні негативна"/>
                    </outline>
                    <outline text="2. Рутина (routine)">
                        <outline text="Звичний стан мозку у відповідь на зачіпку"/>
                        <outline text="Може бути нейтральною, корисною або руйнівною"/>
                    </outline>
                    <outline text="3. Винагорода (reward)">
                        <outline text="Звички живуть через задоволення яке дають"/>
                        <outline text="Прокрастинація легко винагороджує — перехід до приємнішого"/>
                        <outline text="Добрі звички теж потребують винагороди"/>
                    </outline>
                    <outline text="4. Віра (belief)">
                        <outline text="Звички мають владу через віру в них"/>
                        <outline text="Щоб змінити звичку — змініть віру"/>
                        <outline text="Нове товариство і однодумці зміцнюють нову віру"/>
                    </outline>
                </outline>
                <outline text="Як приборкати зомбі">
                    <outline text="Не потрібно масштабно міняти старі звички"/>
                    <outline text="Змінити частково + виробити кілька нових"/>
                    <outline text="Критична точка — реакція на зачіпку (єдине що потребує сили волі)"/>
                </outline>
                <outline text="Робота з елементами через призму прокрастинації">
                    <outline text="Зачіпка">
                        <outline text="Проаналізуйте що вводить вас у зазомбований режим"/>
                        <outline text="Найшкідливіші зачіпки нейтралізуйте (вимкніть телефон/інтернет)"/>
                        <outline text="Корисний ефект створення нових зачіпок (домашка одразу після занять)"/>
                    </outline>
                    <outline text="Рутина">
                        <outline text="Для переформатування потрібен план"/>
                        <outline text="Вироблення нового ритуалу (тихий куточок бібліотеки, без інтернету)"/>
                        <outline text="Метод помідора допомагає при зміні реакцій на зачіпки"/>
                    </outline>
                    <outline text="Винагорода">
                        <outline text="Замініть позитивні емоції від прокрастинації"/>
                        <outline text="Задоволення від завершення навіть чогось невеликого"/>
                        <outline text="Кава, улюблені сайти, похід у кіно за більші досягнення"/>
                        <outline text="Навіть входження в ритм праці може бути винагородою"/>
                        <outline text="Вигадування винагород у певний час створює міні-дедлайни"/>
                    </outline>
                    <outline text="Віра">
                        <outline text="Найважливіше — вірити що ви можете це зробити"/>
                        <outline text="У важкі періоди хочеться повернутися до комфортніших звичок"/>
                        <outline text="Метод контрастів: зіставте теперішню ситуацію з метою"/>
                        <outline text="Уявіть яскраву картину майбутнього і відчуйте контраст"/>
                    </outline>
                </outline>
                <outline text="Процес vs Результат">
                    <outline text="Процес — плин часу і звички (попрацюємо півгодинки)"/>
                    <outline text="Результат — те що маєте завершити (домашня робота)"/>
                    <outline text="Думки про результат породжують неприємні відчуття"/>
                    <outline text="Зазомбована частина мозку любить процеси"/>
                    <outline text="Зосередження на процесі — відхід від оцінювання себе"/>
                </outline>
                <outline text="Метод помідора">
                    <outline text="25 хвилин зосередженої праці без відволікань"/>
                    <outline text="Розроблений Франческо Чірілло у 1980-х"/>
                    <outline text="Легкий стрес від таймера допомагає зосередитися"/>
                    <outline text="Нагорода після кожного сеансу"/>
                    <outline text="Можна чергувати з роботою без таймера"/>
                </outline>
                <outline text="Починайте!">
                    <outline text="Просто почати — якщо зважилися на початок, завершити легше"/>
                    <outline text="Корисно бути де інші працюють (бібліотека)"/>
                    <outline text="Ігноруйте все, що вас відволікає — це найважливіша порада"/>
                    <outline text="Практикуйтесь в ігноруванні відволікальних чинників"/>
                </outline>
                <outline text="Багатозадачність шкодить">
                    <outline text="Постійне перемикання уваги не дає новим ідеям розвинутися"/>
                    <outline text="Зміст роботи не тримається в пам'яті, більше помилок"/>
                    <outline text="Студенти-мультитаскери мають нижчі оцінки"/>
                    <outline text="Відволікаючись хапаємося за неважливі справи (відчуття завершеності)"/>
                </outline>
            </outline>

            <outline text="7. Засвоєння замість заціпеніння">
                <outline text="Як сформувати міцний фрагмент пам'яті">
                    <outline text="Вивчення фундаментальних основ може бути простішим ніж запам'ятовування"/>
                    <outline text="Коли працюєте над задачею — завершення кроку підказує наступний"/>
                    <outline text="Засвоєння розвиває інтуїцію — ви знаєте розв'язання"/>
                </outline>
                <outline text="7 кроків до створення фрагмента пам'яті">
                    <outline text="1. Розв'яжіть задачу від початку до кінця"/>
                    <outline text="2. Розв'яжіть ще раз, зосередившись на ключових процесах"/>
                    <outline text="3. Зробіть перерву — дайте розпорошеному режиму час"/>
                    <outline text="4. Поспіть — перед сном розв'яжіть задачу ще раз"/>
                    <outline text="5. Наступного дня розв'яжіть ще раз (швидше, глибше)"/>
                    <outline text="6. Додайте нову задачу — повторіть кроки 1-5"/>
                    <outline text="7. Працюйте «активно» — пригадуйте під час фізичної активності"/>
                </outline>
                <outline text="Ефект генерування">
                    <outline text="Пригадування матеріалу ефективніше за перечитування"/>
                    <outline text="Мережа нейронів збагачується і підсилюється"/>
                </outline>
                <outline text="Умисне повторення (deliberate practice)">
                    <outline text="Зосередження на найскладніших частинах задачі"/>
                    <outline text="Як музикант працює над найскладнішими фрагментами"/>
                    <outline text="Різниця між гравцями і гросмейстерами — робота зі слабкими місцями"/>
                    <outline text="Хоч утомлює — один з найважливіших аспектів навчання"/>
                </outline>
                <outline text="Закон інтуїції">
                    <outline text="Щастя усміхається тим, хто пробує"/>
                    <outline text="Не лякайтеся обсягу матеріалу — фіксуйте ключові думки"/>
                </outline>
                <outline text="Глухі кути: колапс знань">
                    <outline text="Навчання не завжди йде логічно"/>
                    <outline text="Часом те що здавалося логічним раптом втрачає сенс"/>
                    <outline text="Мозок у стані реструктуризації знань і закладання міцнішого фундаменту"/>
                    <outline text="Після виходу з тимчасового розчарування рівень знань зростає"/>
                </outline>
                <outline text="Організація матеріалу">
                    <outline text="Впорядковуйте вправи й методи розв'язання для тестів"/>
                    <outline text="Писати від руки — інформація частіше залишається в пам'яті"/>
                    <outline text="Робіть підшивку важливих вправ і розв'язань"/>
                </outline>
                <outline text="Тестування як ефективний метод навчання">
                    <outline text="Тест — не тільки оцінка знань, а й процес навчання"/>
                    <outline text="Тестування зміцнює і стабілізує нейронні структури"/>
                    <outline text="Ефект тестування: покращення навіть при поганих результатах"/>
                    <outline text="Створення фрагментів пам'яті = своєрідне міні-тестування"/>
                </outline>
                <outline text="Бібліотека готових розв'язань">
                    <outline text="Створити внутрішню бібліотеку з миттєвим доступом"/>
                    <outline text="Пригадування — найкращий метод навчання (не перечитування)"/>
                    <outline text="Не давайте ілюзіям знання дурити себе"/>
                    <outline text="Будьте терплячими — з практикою стає легше і швидше"/>
                </outline>
                <outline text="Заціпеніння на екзамені">
                    <outline text="Паніка коли оперативна пам'ять переповнена"/>
                    <outline text="Фрагментація стискує знання і вивільняє місце"/>
                    <outline text="Більше місця в оперативній пам'яті = більше деталей"/>
                </outline>
            </outline>

            <outline text="9. Про зомбі-прокрастинації: робимо висновки">
                <outline text="Плюси і мінуси максимальної віддачі">
                    <outline text="Рідкісні творчі прориви відрізняються від типового навчання"/>
                    <outline text="Робота «наскоками» менш продуктивна ніж рівномірні кроки"/>
                    <outline text="Тривала екстремальна робота → ефект вигорання"/>
                </outline>
                <outline text="Гормони стресу та ефективність">
                    <outline text="Наближення дедлайну підвищує стрес"/>
                    <outline text="Помірний стрес стимулює мислення"/>
                    <outline text="Надмірний стрес — здатність мислити зникає"/>
                    <outline text="Математика вимагає нейронного фундаменту — не можна за одну ніч"/>
                </outline>
                <outline text="Мудре очікування">
                    <outline text="Зосередженість не завжди добре — може обмежувати пошук рішень"/>
                    <outline text="Здорова прокрастинація: зупинитися й подумати перш ніж діяти"/>
                    <outline text="Встановлення пріоритетів допомагає поглянути ширше"/>
                </outline>
                <outline text="Зупинитися й подумати">
                    <outline text="Експерти витрачають ~45 сек щоб обрати підхід"/>
                    <outline text="Новачки одразу беруться за розв'язання (~30 сек на роздуми)"/>
                    <outline text="Пауза допомагає побачити задачу в узагальненішій перспективі"/>
                </outline>
                <outline text="Емоції можуть вести хибним шляхом">
                    <outline text="Прагнення йти за мрією може бути як одруження з кінозіркою"/>
                    <outline text="Студенти що сліпо йшли за мріями менш щасливі ніж раціоналісти"/>
                    <outline text="Розвиваємо пристрасть до того що робимо — з результатами приходить захоплення"/>
                </outline>
                <outline text="Скільки часу щоб змінити звичку відкладати">
                    <outline text="Перші результати — майже одразу"/>
                    <outline text="Стійкі звички — близько трьох місяців"/>
                    <outline text="Будьте терплячими — швидкий ефект може бути нетривалим"/>
                </outline>
                <outline text="Сила волі">
                    <outline text="Схожа на м'язи — потрібно регулярно зміцнювати"/>
                    <outline text="Не більше однієї складної справи одночасно"/>
                    <outline text="Метод помідора — універсальний засіб для відволікання зомбі"/>
                </outline>
                <outline text="Відповідальність за результати">
                    <outline text="Якщо постійно думаєте «я не винен» — тут щось не так"/>
                    <outline text="Надмірна впевненість у власних можливостях може набути патологічних форм"/>
                    <outline text="Коваль свого щастя — саме ви"/>
                </outline>
                <outline text="Підсумкові поради">
                    <outline text="Ведіть планувальник — відстежуйте чи досягаєте цілей"/>
                    <outline text="Щодня присвячуйте час виконанню завдань"/>
                    <outline text="Складайте план попереднього вечора"/>
                    <outline text="Розділяйте роботу на багато невеликих завдань з винагородами"/>
                    <outline text="Знаходьте зачіпки що ведуть до прокрастинації"/>
                    <outline text="Свідомо переміщуйтесь у нове оточення (тихий закуток бібліотеки)"/>
                    <outline text="Не звинувачуйте зовнішні чинники — подивіться в дзеркало"/>
                    <outline text="Повірте в новий розпорядок"/>
                    <outline text="Підготуйте запасний план"/>
                    <outline text="«З'їдайте всіх своїх жаб уранці»"/>
                </outline>
            </outline>

        </outline>
    </body>
</opml>